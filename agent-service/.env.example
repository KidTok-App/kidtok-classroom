# ============================================================
# KidTok Classroom agent service — environment configuration
# Copy to .env (or export in your shell) before running locally.
# ============================================================

# --- HTTP -----------------------------------------------------
# Port the Express API listens on (Cloud Run injects PORT automatically).
PORT=8080

# --- Google Cloud ----------------------------------------------
# Project that hosts Vertex AI, Firestore and Cloud Storage.
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# Regional location for regional-policy models (Gemini 3.x always routes to
# the global endpoint regardless — see src/legacy/vertexRouting.ts).
GOOGLE_CLOUD_REGION=us-central1
# Auth uses Application Default Credentials:
#   gcloud auth application-default login
# or set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=

# The Google GenAI SDK used by the ADK engine. config.ts sets these
# automatically from the values above; override only if you know why.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global

# --- Models -----------------------------------------------------
# Text model for all LLM-backed agents (orchestrator brain), via Vertex.
GEMINI_TEXT_MODEL=gemini-3-flash
# Image model for SceneImageAgent, via Vertex.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- Storage ----------------------------------------------------
# Cloud Storage bucket for scene PNGs + narration MP3s. The demo serves
# assets by public URL: either disable uniform bucket-level access (objects
# are made public individually) or grant allUsers roles/storage.objectViewer
# on the bucket.
GCS_BUCKET=your-assets-bucket
# Firestore collection that stores episode documents.
FIRESTORE_COLLECTION=episodes

# --- Text-to-Speech ---------------------------------------------
# Child-friendly en-US voice, slightly slow rate (legacy preset).
TTS_VOICE_NAME=en-US-Neural2-F
TTS_SPEAKING_RATE=0.92
TTS_PITCH=1.0

# --- Arize Phoenix (partner integration) -------------------------
# Phoenix base URL, e.g. https://app.phoenix.arize.com or your self-hosted
# instance. OpenInference spans export to $PHOENIX_HOST/v1/traces.
PHOENIX_HOST=https://app.phoenix.arize.com
PHOENIX_API_KEY=your-phoenix-api-key
# Phoenix project that receives the traces.
PHOENIX_PROJECT=kidtok-classroom
# Optional override for launching the Phoenix MCP server. Default spawns the
# pinned @arizeai/phoenix-mcp from node_modules (hermetic). Example override:
# PHOENIX_MCP_COMMAND=npx -y @arizeai/phoenix-mcp@latest
# Phoenix prompt-management entry that ScenePlannerAgent fetches and
# QualityReviewerAgent improves.
SCENE_PROMPT_NAME=kidtok-scene-prompt

# --- Pipeline behavior -------------------------------------------
# Gemini-based visual safety gate on generated images (legacy gate semantics:
# fail-open on infra errors, block only on a positive unsafe verdict).
ENABLE_VISUAL_ASSET_SAFETY=true
# "adk" = Google Agent Development Kit engine (primary).
# "rest" = documented fallback: plain TypeScript pipeline calling Vertex REST.
ORCHESTRATOR_ENGINE=adk

# --- Test-only ----------------------------------------------------
# 1 = run with in-process fakes (no Google/Phoenix calls). NEVER in production.
KIDTOK_FAKE_PROVIDERS=0
